def projectDir = new File('.').absolutePath
def modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"

    def test_scenario = [
        [
            name: "-profile test --tools sentieon_dnascope",
            params: [
                input: "${projectDir}/tests/csv/3.0/mapped_single_bam.csv",
                tools: "sentieon_dnascope",
                step: "variant_calling"
            ]
        ],
        [
            name: "-profile test --tools sentieon_dnascope --skip_tools dnascope_filter",
            params: [
                input: "${projectDir}/tests/csv/3.0/mapped_single_bam.csv",
                tools: "sentieon_dnascope",
                step: "variant_calling",
                skip_tools: "dnascope_filter"
            ]
        ],
        [
            name: "-profile test --tools sentieon_dnascope --joint_germline --sentieon_dnascope_emit_mode gvcf",
            params: [
                input: "${projectDir}/tests/csv/3.0/mapped_single_bam.csv",
                tools: "sentieon_dnascope",
                step: "variant_calling",
                joint_germline: true,
                sentieon_dnascope_emit_mode: "gvcf"
            ]
        ],
        [
            name: "-profile test --tools sentieon_dnascope --joint_germline --sentieon_dnascope_emit_mode gvcf --sentieon_joint_germline_batch_size 1",
            params: [
                intervals: modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.multi_intervals.bed',
                input: "${projectDir}/tests/csv/3.0/mapped_joint_bam.csv",
                tools: "sentieon_dnascope",
                step: "variant_calling",
                joint_germline: true,
                sentieon_dnascope_emit_mode: "gvcf",
                sentieon_joint_germline_batch_size: 1,
                wes: true,
                nucleotides_per_second: 20
            ],
            no_conda: true
        ]
    ]

    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
