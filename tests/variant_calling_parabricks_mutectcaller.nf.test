def projectDir = new File('.').absolutePath
def modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    profile "test,gpu"

    def test_scenario = [
        [
            name: "-profile test --step variant_calling --tools parabricks_mutectcaller somatic -stub",
            params: [
                genome: null,
                igenomes_ignore: true,
                fasta: modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/genome.fasta',
                fasta_fai: modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/genome.fasta.fai',
                input: "${projectDir}/tests/csv/3.0/recalibrated_somatic.csv",
                intervals: modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/multi_intervals.bed',
                step: "variant_calling",
                tools: 'parabricks_mutectcaller',
                wes: true
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ],
        [
            name: "-profile test --step variant_calling --tools parabricks_mutectcaller somatic --no_intervals -stub",
            params: [
                genome: null,
                igenomes_ignore: true,
                fasta: modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/genome.fasta',
                fasta_fai: modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr21/sequence/genome.fasta.fai',
                input: "${projectDir}/tests/csv/3.0/recalibrated_somatic.csv",
                no_intervals: true,
                step: "variant_calling",
                tools: 'parabricks_mutectcaller',
                wes: true
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ],
        [
            name: "-profile test --aligner parabricks --tools parabricks_mutectcaller somatic -stub",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                aligner: 'parabricks',
                tools: 'parabricks_mutectcaller',
                wes: true
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ],
        [
            name: "-profile test --aligner parabricks --tools parabricks_mutectcaller somatic --no_intervals -stub",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                aligner: 'parabricks',
                tools: 'parabricks_mutectcaller',
                no_intervals: true,
                wes: true
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ],
        [
            name: "-profile test --tools parabricks_mutectcaller somatic -stub",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                tools: 'parabricks_mutectcaller',
                wes: true
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ],
        [
            name: "-profile test --tools parabricks_mutectcaller somatic --no_intervals -stub",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                tools: 'parabricks_mutectcaller',
                no_intervals: true,
                wes: true
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ],
        [
            name: "-profile test --aligner parabricks --tools parabricks_mutectcaller somatic",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                aligner: 'parabricks',
                tools: 'parabricks_mutectcaller',
                wes: true
            ],
            gpu: true,
            no_conda: true
        ],
        [
            name: "-profile test --aligner parabricks --tools parabricks_mutectcaller somatic --no_intervals",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                aligner: 'parabricks',
                tools: 'parabricks_mutectcaller',
                no_intervals: true,
                wes: true
            ],
            gpu: true,
            no_conda: true
        ],
        [
            name: "-profile test --tools parabricks_mutectcaller somatic",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                tools: 'parabricks_mutectcaller',
                wes: true
            ],
            gpu: true,
            no_conda: true
        ],
        [
            name: "-profile test --tools parabricks_mutectcaller somatic --no_intervals",
            params: [
                input: "${projectDir}/tests/csv/3.0/fastq_pair.csv",
                tools: 'parabricks_mutectcaller',
                no_intervals: true,
                wes: true
            ],
            gpu: true,
            no_conda: true
        ]
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
