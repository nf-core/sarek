def projectDir = new File('.').absolutePath

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    profile "test,gpu"

    def test_scenario = [
        [
            name: "-profile test --tools parabricks_deepvariant --input mapped_single_bam.csv",
            params: [
                input: "${projectDir}/tests/csv/3.0/mapped_single_bam.csv",
                step: "variant_calling",
                tools: 'parabricks_deepvariant'
            ],
            gpu: true,
            no_conda: true
        ],
        [
            name: "-profile test --tools parabricks_deepvariant --input mapped_single_bam.csv --no_intervals",
            params: [
                input: "${projectDir}/tests/csv/3.0/mapped_single_bam.csv",
                step: "variant_calling",
                tools: 'parabricks_deepvariant',
                no_intervals: true
            ],
            gpu: true,
            no_conda: true
        ],
        [
            name: "-profile test --tools parabricks_deepvariant --input mapped_single_bam.csv -stub",
            params: [
                input: "${projectDir}/tests/csv/3.0/mapped_single_bam.csv",
                step: "variant_calling",
                tools: 'parabricks_deepvariant'
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ],
        [
            name: "-profile test --tools parabricks_deepvariant --input mapped_single_bam.csv --no_intervals -stub",
            params: [
                input: "${projectDir}/tests/csv/3.0/mapped_single_bam.csv",
                step: "variant_calling",
                tools: 'parabricks_deepvariant',
                no_intervals: true
            ],
            gpu: true,
            no_conda: true,
            stub: true
        ]
    ]

    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
