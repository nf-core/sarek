def projectDir = new File('.').absolutePath

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"

    def test_scenario = [
        [
            name: "-profile test --save_output_as_bam skip QC/recal/md",
            params: [
                save_output_as_bam: true,
                skip_tools: 'baserecalibrator,fastqc,markduplicates,mosdepth,multiqc,samtools',
                tools: ''
            ]
        ],
        [
            name: "-profile test --save_output_as_bam with variant calling",
            params: [
                save_output_as_bam: true,
                tools: 'strelka,cnvkit'
            ]
        ],
        [
            name: "-profile test --save_output_as_bam --tools sentieon_dedup",
            params: [
                save_output_as_bam: true,
                tools: 'sentieon_dedup',
                step: 'markduplicates',
                skip_tools: 'baserecalibrator,fastqc,mosdepth,multiqc,samtools',
                input: "${projectDir}/tests/csv/3.0/mapped_single_cram.csv"
            ]
            sentieon:true,
        ]
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
