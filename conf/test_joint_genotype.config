/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for DeepVariant joint genotyping tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Minimal test of the DeepVariant + GLnexus joint genotyping path, producing one
    multi-sample, VEP-annotated cohort VCF.

    Use as follows:
        nextflow run nf-core/sarek -profile test_joint_genotype,<docker/singularity> --outdir <OUTDIR>
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

includeConfig 'test.config'

params {
    config_profile_name        = 'DeepVariant joint genotyping test profile'
    config_profile_description = 'Minimal test of the DeepVariant + GLnexus joint genotyping path'

    // Three germline samples (recalibrated CRAMs), start straight from variant calling
    input          = "${projectDir}/tests/csv/3.0/joint_germline_deepvariant.csv"
    step           = 'variant_calling'

    // DeepVariant per-sample calling + GLnexus joint genotyping; VEP is auto-enabled by --joint_genotype
    tools          = 'deepvariant'
    joint_genotype = true

    // VEP is auto-enabled by --joint_genotype. The stub nf-test validates the VEP wiring without
    // requiring a pre-staged cache. Real runs fetch the VEP cache through download_cache.
    download_cache = true
}
